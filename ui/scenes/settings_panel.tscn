[gd_scene format=3 uid="uid://settings_panel"]

[ext_resource type="Script" path="res://scripts/settings_panel.gd" id="1_settings_panel"]
[ext_resource type="Theme" path="res://themes/lumi_dark.tres" id="2_theme"]

[node name="SettingsPanel" type="Window"]
title = "Lumi — Settings"
initial_position = 2
size = Vector2i(680, 540)
min_size = Vector2i(500, 400)
visible = false
script = ExtResource("1_settings_panel")
theme = ExtResource("2_theme")

[node name="PanelContainer" type="PanelContainer" parent="."]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="PanelContainer"]
layout_mode = 2

[node name="Header" type="HBoxContainer" parent="PanelContainer/VBox"]
layout_mode = 2

[node name="TitleLabel" type="Label" parent="PanelContainer/VBox/Header"]
layout_mode = 2
size_flags_horizontal = 3
text = "Settings"
theme_override_font_sizes/font_size = 14

[node name="CloseBtn" type="Button" parent="PanelContainer/VBox/Header"]
layout_mode = 2
text = "✕"
tooltip_text = "Close"

[node name="TabContainer" type="TabContainer" parent="PanelContainer/VBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="RestartBar" type="Label" parent="PanelContainer/VBox"]
layout_mode = 2
visible = false
modulate = Color(1, 0.85, 0, 1)
text = "Some changes require a restart to take effect."
theme_override_font_sizes/font_size = 12

[node name="Footer" type="HBoxContainer" parent="PanelContainer/VBox"]
layout_mode = 2
alignment = 2

[node name="CancelBtn" type="Button" parent="PanelContainer/VBox/Footer"]
layout_mode = 2
text = "Cancel"

[node name="ApplyBtn" type="Button" parent="PanelContainer/VBox/Footer"]
layout_mode = 2
text = "Apply"

[node name="SaveBtn" type="Button" parent="PanelContainer/VBox/Footer"]
layout_mode = 2
text = "Save && Restart"
