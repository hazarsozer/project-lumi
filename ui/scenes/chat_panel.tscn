[gd_scene format=3 uid="uid://chat_panel"]

[ext_resource type="Script" path="res://scripts/chat_panel.gd" id="1_chat_panel"]
[ext_resource type="Theme" path="res://themes/lumi_dark.tres" id="2_theme"]

[node name="ChatPanel" type="Window"]
title = "Lumi — Chat"
initial_position = 2
size = Vector2i(380, 540)
min_size = Vector2i(280, 360)
visible = false
script = ExtResource("1_chat_panel")
theme = ExtResource("2_theme")

[node name="PanelContainer" type="PanelContainer" parent="."]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="PanelContainer"]
layout_mode = 2

[node name="Header" type="HBoxContainer" parent="PanelContainer/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)

[node name="TitleLabel" type="Label" parent="PanelContainer/VBox/Header"]
layout_mode = 2
size_flags_horizontal = 3
text = "Chat"
theme_override_font_sizes/font_size = 14

[node name="ClearBtn" type="Button" parent="PanelContainer/VBox/Header"]
layout_mode = 2
custom_minimum_size = Vector2(32, 32)
tooltip_text = "Clear chat history"
text = "🗑"

[node name="MessagesScroll" type="ScrollContainer" parent="PanelContainer/VBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="MessagesVBox" type="VBoxContainer" parent="PanelContainer/VBox/MessagesScroll"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="InputRow" type="HBoxContainer" parent="PanelContainer/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 44)
theme_override_constants/separation = 6

[node name="InputField" type="LineEdit" parent="PanelContainer/VBox/InputRow"]
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Type a message…"

[node name="SendBtn" type="Button" parent="PanelContainer/VBox/InputRow"]
layout_mode = 2
custom_minimum_size = Vector2(40, 32)
tooltip_text = "Send (Enter)"
text = "→"
