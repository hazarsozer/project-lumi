# --- Python Standard ---
__pycache__/
*.pyc
.venv/
.env

# --- AI & Models (CRITICAL) ---
# Ignore all model weights, but keep the folder structure if you want
models/*
*.onnx
*.pt
*.bin
*.gguf
!models/.keep  # (Optional: lets you commit the folder but not the files)

# --- IDEs ---
.vscode/
.idea/

# --- AI Tooling (local workflow, not project code) ---
SUGGESTIONS.md
GEMINI.md
CLAUDE.md
SKILL.md
MVP_REPORT.md

# --- Notebooks ---
*.ipynb

