# --- Claude Code (local session data, agent definitions) ---
.claude/

# --- Godot editor cache (auto-generated, not source) ---
ui/.godot/

# --- Tauri / Node ---
app/node_modules/
app/dist/
app/src-tauri/target/
# Brain sidecar binaries — built by scripts/build_brain.sh, not source.
# Keep the directory itself (Tauri requires the path to exist for cargo check)
# but ignore everything inside it. A stub file should be checked in if the
# directory must be empty in fresh clones.
app/src-tauri/binaries/lumi-brain-*/

# --- PyInstaller build artifacts ---
scripts/build/
scripts/dist/

# --- pytest / coverage ---
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# --- Type checking / linting caches ---
.mypy_cache/
.ruff_cache/

# --- Local planning / scratch files ---
next_session.md
finetune.md
useful-agents.md

# --- Fine-tuning datasets (large, regenerable) ---
data/finetune/*.jsonl
.run_logs/

# Training/eval logs (kept out of repo; preserved on disk for postmortem)
logs/


# Private development knowledge base / second brain (Karpathy's LLM Wiki pattern)
docs/wiki/

